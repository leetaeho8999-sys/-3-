# =====================================================
# ROWNCafe — 환경변수 설정 파일
# 이 파일을 복사해 .env 로 이름 변경 후 실제 값을 입력하세요.
# .env 파일은 절대 Git에 커밋하지 마세요.
# =====================================================

# MySQL 접속 정보
DB_URL=jdbc:mysql://localhost:3306/project?useSSL=false&serverTimezone=Asia/Seoul&allowPublicKeyRetrieval=true&useUnicode=true&characterEncoding=UTF-8&characterSetResults=UTF-8
DB_USERNAME=root
DB_PASSWORD=your_db_password_here

# Groq AI API 키 (https://console.groq.com 에서 발급)
GROQ_API_KEY=gsk_your_api_key_here

# TossPayments 키 (https://developers.tosspayments.com 에서 발급)
# 아래 기본값은 공식 공용 테스트 키 — 개발/테스트 환경에서 그대로 사용 가능
TOSS_CLIENT_KEY=test_ck_docs_Ovk5rk1EwkEbP0W43n07xlzm
TOSS_SECRET_KEY=test_sk_docs_OaPz8L5KdmQXkzRz3y47BMw6
