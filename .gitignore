target/
*.class
*.jar
*.war
*.ear
*.log
.idea/
*.iml
.vscode/
.DS_Store

# 환경변수 (비밀값) — Git에 올리지 말 것
.env
.env.local
.env.*.local

# 로그 디렉토리
logs/

# DB 백업 파일 (mysqldump) — 민감 데이터 포함 가능
backup/

# 사용자 업로드 파일 (서버 로컬, 외부 볼륨 마운트 대상)
uploads/board/*
!uploads/board/.gitkeep

# Docker MySQL 초기화 SQL (덤프 파일은 민감 데이터 포함)
mysql-init/*.sql

# 편집 중 백업 파일
*.bak
*.bak2
*.bak3
*.swp
*.swo
