target/
*.class
*.jar
*.war
*.ear
*.log
.idea/
*.iml
.vscode/
.DS_Store

# 환경변수 (비밀값) — Git에 올리지 말 것
.env
.env.local
.env.*.local

# 로그 디렉토리
logs/

# DB 백업 파일 (mysqldump) — 민감 데이터 포함 가능
backup/

# 업로드된 이미지 (서버 로컬 파일)
src/main/webapp/resources/upload/board/*
!src/main/webapp/resources/upload/board/.gitkeep

# Docker MySQL 초기화 SQL (덤프 파일은 민감 데이터 포함)
mysql-init/*.sql

# 편집 중 백업 파일
*.bak
*.bak2
*.bak3
*.swp
*.swo
