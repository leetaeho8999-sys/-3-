<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.study.cafe.visit.mapper.VisitMapper">

    <resultMap id="visitMap" type="org.study.cafe.visit.vo.VisitVO">
        <id     column="v_idx"       property="vIdx"/>
        <result column="m_id"        property="mId"/>
        <result column="order_id"    property="orderId"/>
        <result column="visit_date"  property="visitDate"/>
        <result column="cancelled"   property="cancelled"/>
        <result column="cancel_date" property="cancelDate"/>
    </resultMap>

    <insert id="insertVisit">
        INSERT INTO visit_t (m_id, order_id) VALUES (#{mId}, #{orderId})
    </insert>

    <!-- 멱등: 이미 cancelled=1 이면 0행 영향 -->
    <update id="cancelVisitByOrder">
        UPDATE visit_t
           SET cancelled   = 1,
               cancel_date = NOW()
         WHERE order_id = #{orderId}
           AND cancelled = 0
    </update>

    <select id="countThisMonthByMember" resultType="int">
        SELECT COUNT(*) FROM visit_t
         WHERE m_id = #{mId}
           AND cancelled = 0
           AND visit_date &gt;= DATE_FORMAT(NOW(), '%Y-%m-01 00:00:00')
    </select>

    <select id="countTotalByMember" resultType="int">
        SELECT COUNT(*) FROM visit_t WHERE m_id = #{mId} AND cancelled = 0
    </select>

    <select id="findByOrderId" resultMap="visitMap">
        SELECT * FROM visit_t WHERE order_id = #{orderId}
    </select>

</mapper>
