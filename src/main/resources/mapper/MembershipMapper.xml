<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.study.cafe.membership.mapper.MembershipMapper">

    <!-- membership_t: ms_idx, user_id, grade, points, reg_date -->
    <resultMap id="membershipMap" type="MembershipVO">
        <result column="ms_idx"   property="ms_idx"/>
        <result column="user_id"  property="userId"/>
        <result column="reg_date" property="regDate"/>
    </resultMap>

    <select id="getByUserId" parameterType="String" resultMap="membershipMap">
        SELECT * FROM membership_t WHERE user_id = #{userId}
    </select>

    <insert id="insertMembership" parameterType="MembershipVO">
        INSERT INTO membership_t (user_id, grade, points) VALUES (#{userId}, #{grade}, #{points})
    </insert>

    <update id="updateMembership" parameterType="MembershipVO">
        UPDATE membership_t SET grade = #{grade}, points = #{points} WHERE user_id = #{userId}
    </update>

    <!-- 등급만 갱신 (포인트는 손대지 않음) -->
    <update id="updateGrade" parameterType="MembershipVO">
        UPDATE membership_t SET grade = #{grade} WHERE user_id = #{userId}
    </update>

    <!-- member 테이블에서 이름 조회 -->
    <select id="getMemberName" parameterType="String" resultType="String">
        SELECT m_name FROM member WHERE m_id = #{mId}
    </select>

    <!-- member.m_phone = customer_t.phone 조인으로 방문 횟수 조회 -->
    <select id="getVisitCountByMId" parameterType="String" resultType="java.lang.Integer">
        SELECT c.visit_count
        FROM member m
        JOIN customer_t c ON m.m_phone = c.phone AND c.active = 0
        WHERE m.m_id = #{mId}
        LIMIT 1
    </select>

</mapper>
