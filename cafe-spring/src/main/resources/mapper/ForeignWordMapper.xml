<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="org.study.cafe.chat.mapper.ForeignWordMapper">

    <!--
        긴 패턴이 먼저 치환되도록 LENGTH(foreign_word) DESC 정렬
        예) 'ありがとうございます' 가 'ございます' 보다 먼저 처리됨
    -->
    <select id="findAll" resultType="map">
        SELECT
            foreign_word AS foreignWord,
            korean_word  AS koreanWord
        FROM foreign_word_map
        ORDER BY LENGTH(foreign_word) DESC
    </select>

</mapper>
