<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.study.cafe.menu.mapper.MenuMapper">

    <!-- menu_t 테이블: image_url→imageUrl 매핑 -->
    <resultMap id="menuMap" type="MenuVO">
        <result column="image_url" property="imageUrl"/>
    </resultMap>

    <select id="getMenuList" parameterType="String" resultMap="menuMap">
        SELECT * FROM menu_t WHERE available = 1
        <if test="_parameter != null"> AND category = #{_parameter} </if>
        ORDER BY m_idx ASC
    </select>

    <select id="getMenuDetail" parameterType="String" resultMap="menuMap">
        SELECT * FROM menu_t WHERE m_idx = #{m_idx}
    </select>

</mapper>
